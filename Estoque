function verificarNotificacoes(){
  var est=getEst();
  var hoje=new Date();
  hoje.setHours(0,0,0,0);
  
  var vencidos=0,vencem_hoje=0,proxima_semana=0;
  
  est.forEach(function(it){
    var partesData=it.v.split('-');
    var dataVenc=new Date(parseInt(partesData[0]),parseInt(partesData[1])-1,parseInt(partesData[2]));
    var diasFaltando=Math.ceil((dataVenc-hoje)/(1000*60*60*24));
    
    if(diasFaltando<0)vencidos++;
    else if(diasFaltando===0)vencem_hoje++;
    else if(diasFaltando<=7)proxima_semana++;
  });
  
  // Mostrar notificações
  if(vencidos>0)avisar('🔴 '+vencidos+' produto(s) vencido(s)!');
  if(vencem_hoje>0)avisar('⚠️ '+vencem_hoje+' produto(s) vence hoje!');
  if(proxima_semana>0)avisar('🟠 '+proxima_semana+' produto(s) vence na semana');
}

