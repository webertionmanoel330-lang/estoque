function exportarDados(){
  var dados={
    lojas:lojas,
    exportado:new Date().toLocaleString('pt-BR'),
    versao:'1.0'
  };
  var json=JSON.stringify(dados,null,2);
  var blob=new Blob([json],{type:'application/json'});
  var url=URL.createObjectURL(blob);
  var a=document.createElement('a');
  a.href=url;
  a.download='estoque_backup_'+new Date().getTime()+'.json';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  avisar('✅ Dados exportados com sucesso!');
}

function importarDados(){
  var input=document.createElement('input');
  input.type='file';
  input.accept='.json';
  input.onchange=function(e){
    var file=e.target.files[0];
    var reader=new FileReader();
    reader.onload=function(event){
      try{
        var dados=JSON.parse(event.target.result);
        if(dados.lojas&&Array.isArray(dados.lojas)){
          lojas=dados.lojas;
          salvarLocal();
          renderTudo();
          avisar('✅ Dados importados com sucesso!');
        }else{
          avisar('❌ Arquivo inválido!');
        }
      }catch(err){
        avisar('❌ Erro ao importar arquivo!');
      }
    };
    reader.readAsText(file);
  };
  input.click();
}

// ========== SCANNER DE CÓDIGO DE BARRAS ==========
function abrirScanner(campoId){
  // Se tem QuaggaJS, usar para ler código de barras real
  if(typeof Quagga!=='undefined'){
    // Criar modal para câmera
    var scannerDiv=document.createElement('div');
    scannerDiv.id='scanner-modal';
    scannerDiv.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;';
    
    var titulo=document.createElement('div');
    titulo.style.cssText='color:#fff;font-size:16px;font-weight:700;margin-bottom:20px;text-align:center;';
    titulo.textContent='📷 Aponte para o código de barras';
    scannerDiv.appendChild(titulo);
    
    var videoEl=document.createElement('video');
    videoEl.id='quagga-video';
    videoEl.style.cssText='width:100%;max-width:400px;border:2px solid #e05252;border-radius:10px;';
    scannerDiv.appendChild(videoEl);
    
    var btnFechar=document.createElement('button');
    btnFechar.style.cssText='margin-top:20px;padding:10px 20px;background:#e05252;color:#fff;border:none;border-radius:8px;font-weight:700;cursor:pointer;';
    btnFechar.textContent='Cancelar';
    btnFechar.onclick=function(){
      Quagga.stop();
      scannerDiv.remove();
    };
    scannerDiv.appendChild(btnFechar);
    
    document.body.appendChild(scannerDiv);
    
    // Iniciar Quagga
    Quagga.init({
      inputStream:{
        name:'Live',
        type:'LiveStream',
        target:videoEl,
        constraints:{facingMode:'environment',width:640,height:480}
      },
      decoder:{readers:['ean_reader','ean_8_reader','upc_reader','codabar_reader','code_128_reader']}
    },function(err){
      if(err){
        avisar('❌ Câmera não disponível');
        scannerDiv.remove();
        return;
      }
      Quagga.start();
      
      Quagga.onDetected(function(result){
        if(result.codeResult&&result.codeResult.code){
          var codigo=result.codeResult.code;
          document.getElementById(campoId).value=codigo;
          if(campoId==='fc')validarForm();
          if(campoId==='busca')rEst();
          avisar('✅ Código: '+codigo);
          Quagga.stop();
          scannerDiv.remove();
        }
      });
    });
  }else{
    // Fallback se QuaggaJS não estiver disponível
    var codigo=prompt('📷 Digite o código do produto:');
    if(codigo){
      document.getElementById(campoId).value=codigo;
      if(campoId==='fc')validarForm();
      if(campoId==='busca')rEst();
      avisar('✅ Código: '+codigo);
    }
  }
}

