<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Gestão de Estoque</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{--bg:#0d0d0d;--sf:#1a1a1a;--sf2:#242424;--bd:#2e2e2e;--tx:#fff;--tx2:#8a8a8a;--red:#e05252;}
html.tema-claro{--bg:#f5f5f5;--sf:#ffffff;--sf2:#f0f0f0;--bd:#e0e0e0;--tx:#1a1a1a;--tx2:#666666;}
:root.tema-claro{--bg:#f5f5f5;--sf:#ffffff;--sf2:#eeeeee;--bd:#dddddd;--tx:#1a1a1a;--tx2:#666666;--red:#e05252;}
html,body{height:100%;background:var(--bg);color:var(--tx);font-family:'Inter',sans-serif;overflow:hidden;}
#app{max-width:430px;margin:0 auto;height:100vh;display:flex;flex-direction:column;position:relative;overflow:hidden;}
.screen{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;background:var(--bg);opacity:0;transform:translateY(10px);transition:opacity .22s ease,transform .22s ease;pointer-events:none;}
.screen.active{opacity:1;transform:translateY(0);pointer-events:auto;}
.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:88px;}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:16px 20px 12px;flex-shrink:0;}
.pill{display:flex;align-items:center;gap:6px;background:var(--sf);border:1px solid var(--bd);border-radius:20px;padding:8px 14px;cursor:pointer;font-size:14px;font-weight:600;}
.pill:active{background:var(--sf2);}
.ibtn{width:40px;height:40px;border-radius:50%;background:var(--sf);border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;}
.ibtn:active{background:var(--sf2);}
.ph{padding:6px 20px 12px;}
.ptitle{font-size:32px;font-weight:800;}
.sw{padding:0 20px 12px;}
.sbox{background:var(--sf);border:1px solid var(--bd);border-radius:12px;padding:10px 14px;display:flex;align-items:center;gap:8px;}
.sbox input{background:transparent;border:none;color:var(--tx);font-size:14px;font-family:'Inter',sans-serif;width:100%;outline:none;}
.clist{padding:0 16px;display:flex;flex-direction:column;gap:10px;}
.card{background:var(--sf);border:1px solid var(--bd);border-radius:14px;padding:12px 14px;cursor:pointer;}
.cname{font-size:15px;font-weight:600;margin-bottom:6px;}
.bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:rgba(10,10,10,.96);border-top:1px solid var(--bd);display:flex;z-index:100;}
.nitem{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0 12px;cursor:pointer;gap:3px;border:none;background:transparent;color:var(--tx2);font-family:'Inter',sans-serif;font-size:12px;}
.nitem.active{color:var(--red);}
.nitem div{font-size:24px;}
.fab{position:fixed;bottom:90px;right:16px;width:56px;height:56px;background:var(--red);border-radius:50%;border:none;color:#fff;font-size:32px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:50;font-weight:700;}
.fab:active{transform:scale(.92);}
.ov{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:90;display:none;}
.ov.open{display:block;}
.panel{position:fixed;top:0;left:0;width:100%;max-width:430px;height:100vh;background:var(--bg);z-index:95;overflow-y:auto;transform:translateX(-100%);transition:transform .3s cubic-bezier(.32,.72,0,1);}
.panel.open{transform:translateX(0);}
.panel-header{display:flex;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid var(--bd);flex-shrink:0;justify-content:flex-start;}
.panel-back{background:transparent;border:none;width:auto;height:auto;border-radius:0;cursor:pointer;color:var(--red);font-size:32px;display:flex;align-items:center;justify-content:center;font-weight:700;transition:all .2s;line-height:1.2;padding:0;letter-spacing:0;margin-right:8px;transform:translateY(-2px);}
.panel-back:active{background:var(--sf2);}
.panel-title{font-size:20px;font-weight:700;}
.panel-body{padding:16px;}
.drawer{background:#181818;border-radius:20px 20px 0 0;width:100%;max-width:430px;max-height:90vh;overflow-y:auto;animation:sup .25s ease;}
@keyframes sup{from{transform:translateY(100%);}to{transform:translateY(0);}}
.dhandle{width:32px;height:3px;background:var(--bd);border-radius:2px;margin:10px auto;}
.dhead{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--bd);}
.dtitle{font-size:16px;font-weight:700;}
.dclose{background:var(--sf2);border:none;width:32px;height:32px;border-radius:50%;cursor:pointer;color:var(--red);font-size:18px;display:flex;align-items:center;justify-content:center;font-weight:700;transition:all .2s;}
.dclose:active{background:rgba(224,82,82,.1);}
.sbtn{background:var(--red);border:none;border-radius:8px;padding:6px 16px;color:#fff;font-size:13px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;width:100%;}
.sbtn:disabled{opacity:0.3;cursor:not-allowed;}
.sbtn span{color:#fff;font-weight:700;}
.dbody{padding:18px;}
.fcol{display:flex;flex-direction:column;gap:4px;}
.ffull{margin-bottom:12px;}
.flbl{font-size:10px;font-weight:600;letter-spacing:.08em;color:var(--tx2);text-transform:uppercase;}
.req-row{display:flex;align-items:center;gap:2px;margin-bottom:4px;}
.req-star{color:var(--red);font-size:12px;font-weight:800;}
.finp{background:var(--sf2);border:1px solid var(--bd);border-radius:8px;padding:10px 12px;color:var(--tx);font-size:14px;font-family:'Inter',sans-serif;outline:none;width:100%;}
.finp:focus{border-color:var(--red);}
input[type="date"]{background:var(--sf2)!important;border:1px solid var(--bd)!important;border-radius:8px!important;padding:10px 12px!important;color:var(--tx)!important;font-size:14px!important;font-family:'Inter',sans-serif!important;outline:none!important;width:100%!important;cursor:pointer!important;}
input[type="date"]:focus{border-color:var(--red)!important;}
input[type="date"]::-webkit-calendar-picker-indicator{filter:invert(1);cursor:pointer;}
.sopts{display:flex;flex-direction:column;gap:6px;}
.sopt{background:var(--sf2);border:1.5px solid var(--bd);border-radius:8px;padding:10px 12px;cursor:pointer;font-size:13px;font-weight:600;color:var(--tx2);text-align:left;width:100%;font-family:'Inter',sans-serif;}
.sopt.sel{border-color:var(--red);color:var(--red);background:rgba(224,82,82,.08);}
.scan-btn{background:var(--red);border:none;color:#fff;width:36px;height:36px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.scan-btn:active{opacity:.8;}
.tw{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);z-index:10000;width:calc(100% - 32px);max-width:398px;}
.toast{padding:10px 14px;border-radius:10px;font-size:13px;font-weight:600;width:100%;text-align:center;background:#2a2a2a;color:#fff;animation:ti .2s ease;margin-bottom:8px;}
.toast{padding:10px 14px;border-radius:10px;font-size:13px;font-weight:600;width:100%;text-align:center;background:#2a2a2a;color:#fff;animation:ti .2s ease;margin-bottom:8px;}
.undo-toast{background:var(--sf);border:1px solid var(--bd);border-radius:10px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;animation:ti .2s ease;}
.undo-bar{flex:1;height:3px;background:var(--red);border-radius:2px;overflow:hidden;}
.undo-fill{height:100%;background:var(--red);animation:undo-countdown 5s linear forwards;}
.undo-close{background:transparent;border:none;color:var(--tx);font-size:18px;cursor:pointer;padding:0;width:24px;height:24px;display:flex;align-items:center;justify-content:center;}
@keyframes undo-countdown{from{width:100%;}to{width:0%;}}
@keyframes countdown{from{width:100%;}to{width:0%;}}
@keyframes ti{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.empty{text-align:center;padding:50px 20px;color:var(--tx2);font-size:13px;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}

/* ===== CLASSES PARA OTIMIZAÇÃO - Reduzir inline styles ===== */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;}
.modal-container{background:var(--sf);border-radius:12px;padding:0;width:100%;max-width:320px;max-height:70vh;overflow-y:auto;}
.modal-item{padding:14px;border-bottom:1px solid var(--bd);cursor:pointer;display:flex;align-items:center;gap:10px;color:var(--tx);font-size:14px;}
.modal-item:hover{background:var(--sf2);}
.modal-radio{width:20px;height:20px;border:2px solid var(--tx2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.modal-radio.active{background:var(--red);border-color:var(--red);}
.modal-radio.active::after{content:'';width:8px;height:8px;background:#fff;border-radius:50%;}
.modal-label{flex:1;}

.btn-primary{width:100%;padding:12px;background:var(--red);color:#fff;border:none;border-radius:8px;font-weight:700;cursor:pointer;font-size:14px;font-family:'Inter',sans-serif;}
.btn-secondary{width:100%;padding:12px;background:var(--sf2);color:var(--tx);border:none;border-radius:8px;font-weight:700;cursor:pointer;font-size:14px;font-family:'Inter',sans-serif;}
.btn-danger{width:100%;padding:12px;background:rgba(224,82,82,.2);color:var(--red);border:none;border-radius:8px;font-weight:700;cursor:pointer;font-size:14px;font-family:'Inter',sans-serif;}

.form-group{margin-bottom:14px;}
.form-label{font-size:11px;font-weight:600;color:var(--tx2);text-transform:uppercase;display:block;margin-bottom:6px;}
.form-input{background:var(--sf2);border:1px solid var(--bd);border-radius:8px;padding:10px 12px;color:var(--tx);font-size:14px;font-family:'Inter',sans-serif;outline:none;width:100%;}

.card-item{background:var(--sf2);border:1px solid var(--bd);border-radius:8px;padding:12px;margin:8px;}
.card-title{font-weight:700;color:var(--tx);font-size:14px;margin-bottom:6px;}
.card-subtitle{color:var(--tx2);font-size:12px;margin-bottom:6px;font-family:monospace;}
.card-footer{font-size:11px;color:var(--tx2);padding-top:6px;border-top:1px solid var(--bd);margin-top:6px;}

.toast-message{padding:14px;border-bottom:1px solid var(--bd);background:var(--sf2);border-radius:8px;margin:8px;}
.toast-title{font-weight:700;color:var(--tx);font-size:14px;}
.toast-subtitle{color:var(--tx2);font-size:12px;margin-top:4px;}

</style>
<script src="https://cdn.jsdelivr.net/npm/quagga@0.12.1/dist/quagga.min.js"></script>
</head>
<body>

<div id="app">
  <div class="screen active" id="s-estoque">
    <div class="topbar">
      <div class="pill" data-action="abrirLojas"><span style="width:8px;height:8px;border-radius:50%;background:var(--red);"></span><span id="ln-e">Loja 1</span></div>
      <div style="display:flex;gap:6px;"><div class="ibtn" data-action="abrirSync" style="cursor:pointer;">🔗</div><div class="ibtn" data-action="abrirCfg" style="cursor:pointer;">⚙️</div></div>
    </div>
    <div class="ph"><div style="display:flex;justify-content:space-between;align-items:baseline;"><div class="ptitle" data-trad="Solicitado">Solicitado</div><div style="font-size:13px;color:var(--tx2);" id="cnt">0 itens</div></div></div>
    <div class="sw"><div class="sbox"><input id="busca" placeholder="Buscar..." data-trad-placeholder="Buscar" oninput="rEst()"><button class="scan-btn" data-action="abrirScannerBusca" style="background:transparent;border:none;width:40px;height:40px;padding:0;cursor:pointer;"><svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;"><g stroke="#e05252" stroke-width="5" stroke-linecap="round"><path d="M 20 45 L 20 25 Q 20 15 30 15 L 45 15"/><path d="M 100 45 L 100 25 Q 100 15 90 15 L 75 15"/><path d="M 20 75 L 20 95 Q 20 105 30 105 L 45 105"/><path d="M 100 75 L 100 95 Q 100 105 90 105 L 75 105"/></g><g stroke="#e05252" stroke-width="3" stroke-linecap="round"><line x1="30" y1="40" x2="30" y2="55"/><line x1="42" y1="40" x2="42" y2="55"/><line x1="54" y1="40" x2="54" y2="55"/><line x1="66" y1="40" x2="66" y2="55"/><line x1="78" y1="40" x2="78" y2="55"/><line x1="90" y1="40" x2="90" y2="55"/><line x1="15" y1="60" x2="105" y2="60" stroke-width="4"/><line x1="30" y1="65" x2="30" y2="80"/><line x1="42" y1="65" x2="42" y2="80"/><line x1="54" y1="65" x2="54" y2="80"/><line x1="66" y1="65" x2="66" y2="80"/><line x1="78" y1="65" x2="78" y2="80"/><line x1="90" y1="65" x2="90" y2="80"/></g></svg></button></div></div>
    
    <!-- Filtros Avançados -->
    <div style="display:flex;gap:8px;padding:8px;background:var(--sf);border-radius:8px;margin:0 0 12px 0;">
      <button id="btn-filtro-status" style="flex:1;background:var(--sf2);border:1px solid var(--bd);border-radius:6px;padding:6px;color:var(--tx);font-size:12px;font-family:'Inter',sans-serif;cursor:pointer;text-align:left;" data-action="abrirModalStatus">📌 Todos Status</button>
      <input type="hidden" id="filtro-status">
      
      <button id="btn-filtro-dias" style="flex:1;background:var(--sf2);border:1px solid var(--bd);border-radius:6px;padding:6px;color:var(--tx);font-size:12px;font-family:'Inter',sans-serif;cursor:pointer;text-align:left;" data-action="abrirModalPeriodos">📅 Todos Períodos</button>
      <input type="hidden" id="filtro-dias">
    </div>
    <div class="ph"><div class="ptitle">Solicitado</div></div>
    <div class="scroll"><div class="clist" id="le"></div></div>
    
    <div class="ph"><div class="ptitle" data-trad="Baixa">Baixa de Preço</div></div>
    <div class="scroll"><div class="clist" id="lb"></div></div>
  </div>

  <div class="screen" id="s-aguardando">
    <div class="topbar">
      <div class="pill" data-action="abrirLojas"><span style="width:8px;height:8px;border-radius:50%;background:var(--red);"></span><span id="ln-a">Loja 1</span></div>
      <div style="display:flex;gap:6px;"><div class="ibtn" data-action="abrirSync" style="cursor:pointer;">🔗</div><div class="ibtn" data-action="abrirCfg" style="cursor:pointer;">⚙️</div></div>
    </div>
    <div class="ph"><div class="ptitle" data-trad="Aguardando">Aguardando</div></div>
    <div class="scroll"><div class="clist" id="la"></div></div>
  </div>

  <div class="screen" id="s-dashboard">
    <div class="topbar">
      <div class="pill" data-action="abrirLojas"><span style="width:8px;height:8px;border-radius:50%;background:var(--red);"></span><span id="ln-d">Loja 1</span></div>
      <div style="display:flex;gap:6px;"><div class="ibtn" data-action="abrirSync" style="cursor:pointer;">🔗</div><div class="ibtn" data-action="abrirCfg" style="cursor:pointer;">⚙️</div></div>
    </div>
    <div class="ph"><div class="ptitle" data-trad="Resumo">Resumo</div></div>
    <div class="scroll"><div class="clist" id="ld"></div></div>
  </div>

  <button class="fab" data-action="abrirFormNovo">+</button>
  <nav class="bnav">
    <button class="nitem active" id="n-estoque" data-action="irParaEstoque"><div>📦</div><div>Solicitado</div></button>
    <button class="nitem" id="n-aguardando" data-action="irParaAguardando"><div>⏰</div><div>Aguardando</div></button>
    <button class="nitem" id="n-dashboard" data-action="irParaDashboard"><div>📈</div><div>Resumo</div></button>
  </nav>
</div>

<!-- PAINEL DE LOJAS -->
<div class="ov" id="ov-lojas" data-action="fecharLojas"></div>
<div class="panel" id="p-lojas">
  <div class="panel-header">
    <button class="panel-back" data-action="fecharLojas">←</button>
    <div class="panel-title">Lojas</div>
  </div>
  <div class="panel-body">
    <div id="ll"></div>
    <button class="sbtn" data-action="abrirNovaLoja" style="margin-top:20px;"><span>+</span> Adicionar Loja</button>
  </div>
</div>

<!-- MODAL MENU LOJA -->
<div style="position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:999;display:none;align-items:center;justify-content:center;padding:20px;" id="modal-menu-loja">
  <div style="background:#1a1a1a;border:1px solid var(--bd);border-radius:16px;padding:24px;width:100%;max-width:300px;">
    <h3 id="menu-loja-titulo" style="font-size:16px;font-weight:700;margin-bottom:20px;text-align:center;"></h3>
    
    <button id="btn-selecionar-loja" style="width:100%;padding:12px;margin-bottom:8px;border-radius:8px;border:none;background:var(--red);color:#fff;font-size:14px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;" data-trad="SeleccionarLoja">Selecionar Loja</button>
    
    <button id="btn-limpar-loja" style="width:100%;padding:12px;margin-bottom:8px;border-radius:8px;border:none;background:var(--sf2);color:var(--tx);font-size:14px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;" data-trad="LimparProdutos">🧹 Limpar Produtos</button>
    
    <button id="btn-deletar-loja" style="width:100%;padding:12px;margin-bottom:8px;border-radius:8px;border:none;background:rgba(224,82,82,.2);color:var(--red);font-size:14px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;" data-trad="DeletarLoja">🗑️ Deletar Loja</button>
    
    <button style="width:100%;padding:12px;border-radius:8px;border:none;background:var(--sf2);color:var(--tx);font-size:14px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;" data-action="fecharMenuLoja" data-trad="Cancelar">Cancelar</button>
  </div>
</div>

<!-- MODAL NOVA LOJA -->
<div style="position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:999;display:none;align-items:center;justify-content:center;padding:20px;" id="modal-nova-loja">
  <div style="background:#1a1a1a;border:1px solid var(--bd);border-radius:16px;padding:24px;width:100%;max-width:320px;">
    <h3 style="font-size:16px;font-weight:700;margin-bottom:16px;" data-trad="NovaLoja">Nova Loja</h3>
    
    <div style="margin-bottom:14px;">
      <label style="font-size:11px;font-weight:600;color:var(--tx2);text-transform:uppercase;display:block;margin-bottom:6px;" data-trad="Numero">Número</label>
      <input type="text" id="nl-numero" placeholder="Ex: 1, 2, 3..." style="background:var(--sf2);border:1px solid var(--bd);border-radius:8px;padding:10px 12px;color:var(--tx);font-size:14px;font-family:'Inter',sans-serif;outline:none;width:100%;" oninput="validarNovaLoja()">
    </div>
    
    <div style="margin-bottom:20px;">
      <label style="font-size:11px;font-weight:600;color:var(--tx2);text-transform:uppercase;display:block;margin-bottom:6px;" data-trad="Cidade">Cidade</label>
      <input type="text" id="nl-cidade" placeholder="Ex: São Paulo..." style="background:var(--sf2);border:1px solid var(--bd);border-radius:8px;padding:10px 12px;color:var(--tx);font-size:14px;font-family:'Inter',sans-serif;outline:none;width:100%;" oninput="validarNovaLoja()">
    </div>
    
    <div style="display:flex;gap:10px;">
      <button style="flex:1;padding:10px;border-radius:8px;border:none;background:var(--sf2);color:var(--tx);font-size:13px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;" data-action="fecharNovaLoja" data-trad="Cancelar">Cancelar</button>
      <button style="flex:1;padding:10px;border-radius:8px;border:none;background:var(--red);color:#fff;font-size:13px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;" id="btn-nova-loja" disabled data-action="confirmarNovaLoja" data-trad="Salvar">Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL CONFIRMAR DELETAR LOJA -->
<div style="position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:999;display:none;align-items:center;justify-content:center;padding:20px;" id="modal-confirmar-deletar">
  <div style="background:#1a1a1a;border:1px solid var(--bd);border-radius:16px;padding:24px;width:100%;max-width:300px;">
    <h3 style="font-size:16px;font-weight:700;margin-bottom:12px;text-align:center;">Deletar Loja?</h3>
    <p style="font-size:13px;color:var(--tx2);margin-bottom:20px;text-align:center;" id="msg-deletar-loja"></p>
    
    <div style="display:flex;gap:10px;">
      <button style="flex:1;padding:10px;border-radius:8px;border:none;background:var(--sf2);color:var(--tx);font-size:13px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;" data-action="fecharConfirmarDeletar" data-trad="Cancelar">Cancelar</button>
      <button style="flex:1;padding:10px;border-radius:8px;border:none;background:var(--red);color:#fff;font-size:13px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;" data-action="executarDeletarLoja">Confirmar</button>
    </div>
  </div>
