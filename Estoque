// ===== HELPERS PARA CRIAÇÃO DE ELEMENTOS =====
function criarDiv(classe,conteudo){
  var div=document.createElement('div');
  if(classe)div.className=classe;
  if(conteudo)div.textContent=conteudo;
  return div;
}

function criarBtn(classe,texto,onclick){
  var btn=document.createElement('button');
  if(classe)btn.className=classe;
  if(texto)btn.textContent=texto;
  if(onclick)btn.onclick=onclick;
  return btn;
}

function criarInput(tipo,id,placeholder){
  var inp=document.createElement('input');
  inp.type=tipo||'text';
  if(id)inp.id=id;
  if(placeholder)inp.placeholder=placeholder;
  return inp;
}

// ===== CACHE DE ELEMENTOS DO DOM - OTIMIZAÇÃO =====
