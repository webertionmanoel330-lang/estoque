function abrirSeletorData(){
  var hoje=new Date();
  var dia=document.getElementById('sel-dia');
  var mes=document.getElementById('sel-mes');
  var ano=document.getElementById('sel-ano');
  var ovData=document.getElementById('ov-data');
  var modalData=document.getElementById('modal-data');
  
  if(dia)dia.value=String(hoje.getDate()).padStart(2,'0');
  if(mes)mes.value=String(hoje.getMonth()+1).padStart(2,'0');
  if(ano)ano.value=hoje.getFullYear();
  if(ovData)ovData.style.display='block';
  if(modalData)modalData.style.display='block';
}

function fecharSeletorData(){
  var ovData=document.getElementById('ov-data');
  var modalData=document.getElementById('modal-data');
  if(ovData)ovData.style.display='none';
  if(modalData)modalData.style.display='none';
}

function confirmarData(){
  var diaEl=document.getElementById('sel-dia');
  var mesEl=document.getElementById('sel-mes');
  var anoEl=document.getElementById('sel-ano');
  var fvEl=document.getElementById('fv');
  var dataSelEl=document.getElementById('data-selecionada');
  
  var dia=diaEl?String(diaEl.value).padStart(2,'0'):'';
  var mes=mesEl?String(mesEl.value).padStart(2,'0'):'';
  var ano=anoEl?anoEl.value:'';
  
  if(!dia||!mes||!ano){avisar('⚠️ Preencha todos os campos');return;}
  
  var dataStr=ano+'-'+mes+'-'+dia;
  if(fvEl)fvEl.value=dataStr;
  if(dataSelEl)dataSelEl.textContent=dia+'/'+mes+'/'+ano;
  fecharSeletorData();
  validarForm();
}

function confirmarNovaLoja(){
  var nEl=document.getElementById('nl-numero');
  var cEl=document.getElementById('nl-cidade');
  
  var n=(nEl?nEl.value:'').trim();
  var c=(cEl?cEl.value:'').trim();
  if(!n||!c){avisar('⚠️ Preencha tudo');return;}
  var nc='Loja '+n+' - '+c;
  if(lojas.find(function(l){return l.nome===nc;})){avisar('⚠️ Já existe');return;}
  lojas.push({id:'loja_'+Date.now(),nome:nc,dados:[]});
  lojaAtiva=lojas[lojas.length-1].id;
  salvarLocal();
  renderLojas();
  renderTudo();
  fecharNovaLoja();
  avisar('✅ '+nc+' criada');
}

function abrirConfirmarDeletar(lojaId,lojaNome){
  if(lojas.length<=1){avisar('⚠️ Não pode deletar única loja');return;}
  window._lojaIdDeletar=lojaId;
  window._lojaNomeDeletar=lojaNome;
  var msg=document.getElementById('msg-deletar-loja');
  var modal=document.getElementById('modal-confirmar-deletar');
  if(msg)msg.textContent='Tem certeza que deseja deletar "'+lojaNome+'"?';
  if(modal)modal.style.display='flex';
  fecharMenuLoja();
}

function fecharConfirmarDeletar(){
  var modal=document.getElementById('modal-confirmar-deletar');
  if(modal)modal.style.display='none';
}

function executarDeletarLoja(){
  var lojaId=window._lojaIdDeletar;
  var lojaIndex=lojas.findIndex(function(l){return l.id===lojaId;});
  var lojaAntiga=lojas[lojaIndex];
  ultimaAcao={tipo:'deletar',indice:lojaIndex,lojaAntiga:JSON.parse(JSON.stringify(lojaAntiga))};
  lojas=lojas.filter(function(l){return l.id!==lojaId;});
  if(lojaAtiva===lojaId)lojaAtiva=lojas[0].id;
  salvarLocal();
  registrarMudanca('Loja','Deletada: '+lojaAntiga.nome);
  renderLojas();
  renderTudo();
  fecharConfirmarDeletar();
  mostrarBarraDesfazer('Loja será deletada');
}

function abrirConfirmarLimpar(lojaId,lojaNome){
  window._lojaIdLimpar=lojaId;
  window._lojaNomeLimpar=lojaNome;
  var msg=document.getElementById('msg-limpar-loja');
  var modal=document.getElementById('modal-confirmar-limpar');
  if(msg)msg.textContent='Tem certeza que deseja limpar todos os produtos de "'+lojaNome+'"?';
  if(modal)modal.style.display='flex';
  fecharMenuLoja();
}

function fecharConfirmarLimpar(){
  var modal=document.getElementById('modal-confirmar-limpar');
  if(modal)modal.style.display='none';
}

function executarLimparLoja(){
  var lojaId=window._lojaIdLimpar;
  var loja=lojas.find(function(l){return l.id===lojaId;});
  if(loja){
    ultimaAcao={tipo:'limpar',lojaId:lojaId,dadosAntigos:JSON.parse(JSON.stringify(loja.dados))};
    loja.dados=[];
    salvarLocal();
    registrarMudanca('Loja','Limpada: '+window._lojaNomeLimpar+' ('+ultimaAcao.dadosAntigos.length+' produtos)');
    renderLojas();
    renderTudo();
    fecharConfirmarLimpar();
    mostrarBarraDesfazer('Produtos serão removidos');
  }
}

function irPara(t){
  fecharLojas();
  document.querySelectorAll('.screen').forEach(function(s){s.classList.remove('active');});
  var screen=document.getElementById('s-'+t);
  if(screen)screen.classList.add('active');
  document.querySelectorAll('.nitem').forEach(function(n){n.classList.remove('active');});
  var nitem=document.getElementById('n-'+t);
  if(nitem)nitem.classList.add('active');
  if(t==='estoque')rEst();else if(t==='aguardando')rAg();else rRes();
}

