function importarCSV(){
  var inp=document.createElement('input');
  inp.type='file';
  inp.accept='.csv';
  inp.onchange=function(e){
    var file=e.target.files[0];
    if(file){
      var reader=new FileReader();
      reader.onload=function(evt){
        var csv=evt.target.result;
        var linhas=csv.split('\n');
        var importados=0;
        for(var i=1;i<linhas.length;i++){
          if(linhas[i].trim()){
            var cols=linhas[i].split(',');
            if(cols.length>=4){
              var est=getEst();
              est.push({id:Date.now()+i,c:cols[0].trim(),d:cols[1].trim(),v:cols[2].trim(),s:cols[3].trim()||'SOLICITADO'});
              importados++;
            }
          }
        }
        salvarLocal();
        renderTudo();
        avisar('✅ '+importados+' produtos importados!');
      };
      reader.readAsText(file);
    }
  };
  inp.click();
}

