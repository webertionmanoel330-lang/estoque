function abrirMenuLoja(lojaId,lojaNome){
  var titulo=document.getElementById('menu-loja-titulo');
  var btnSel=document.getElementById('btn-selecionar-loja');
  var btnLimp=document.getElementById('btn-limpar-loja');
  var btnDel=document.getElementById('btn-deletar-loja');
  var modal=document.getElementById('modal-menu-loja');
  
  if(titulo)titulo.textContent=lojaNome;
  if(btnSel)btnSel.onclick=function(){lojaAtiva=lojaId;salvarLocal();renderTudo();fecharLojas();fecharMenuLoja();};
  if(btnLimp)btnLimp.onclick=function(){abrirConfirmarLimpar(lojaId,lojaNome);};
  if(btnDel)btnDel.onclick=function(){abrirConfirmarDeletar(lojaId,lojaNome);};
  if(modal)modal.style.display='flex';
}

