function validarForm(){
  var fc=el('fc');
  var fd=el('fd');
  var fv=el('fv');
  var btn=el('btn-salvar');
  
  var c=(fc?fc.value:'').trim();
  var d=(fd?fd.value:'').trim();
  var v=(fv?fv.value:'').trim();
  
  if(btn)btn.disabled=!(c&&d&&v);
}

function selSt(btn){
  if(!btn)return;
  document.querySelectorAll('.sopt').forEach(function(b){b.classList.remove('sel');});
  btn.classList.add('sel');
  stSel=btn.dataset.s;
}

function salvar(){
  var est=getEst();
  var fcEl=el('fc');
  var fdEl=el('fd');
  var fvEl=el('fv');
  
  var c=(fcEl?fcEl.value:'').trim();
  var d=(fdEl?fdEl.value:'').trim();
  var v=(fvEl?fvEl.value:'').trim();
  
  // Validação 1: Campos obrigatórios
  if(!c||!d||!v){avisar('⚠️ Preencha obrigatórios');return;}
  
  // Validação 2: Descrição não pode ser vazia após trim
  if(d.length===0){avisar('⚠️ Descrição não pode estar vazia');return;}
  
  // Validação 3: Data de vencimento não pode ser no passado
  var partesData=v.split('-');
  var ano=parseInt(partesData[0]);
  var mes=parseInt(partesData[1])-1;
  var dia=parseInt(partesData[2]);
  var dataVencimento=new Date(ano,mes,dia);
  var hoje=new Date();
  hoje.setHours(0,0,0,0);
  
  if(dataVencimento<hoje){
    avisar('⚠️ Data de vencimento não pode ser no passado');
    return;
  }
  
  // Validação 4: Código duplicado (mas permite se data for diferente)
  if(!idEd){
    var codigoExistente=est.find(function(x){return x.c===c&&x.v===v;});
    if(codigoExistente){
      avisar('⚠️ Este código já existe com essa data de vencimento');
      return;
    }
    
    // Se código existe com data diferente, avisa mas permite
    var codigoOutraData=est.find(function(x){return x.c===c;});
    if(codigoOutraData){
      avisar('ℹ️ Código já lançado com data: '+codigoOutraData.v);
    }
  }
  
  var dados={c:c,d:d,v:v,s:stSel};
  if(idEd){
    var i=est.findIndex(function(x){return x.id===idEd;});
    est[i]=Object.assign({},est[i],dados);
  }else{
    est.push(Object.assign({id:Date.now()},dados));
  }
  setEst(est);
  registrarMudanca('Produto',idEd?'Editado: '+d:'Adicionado: '+d);
  fecharForm();
  renderTudo();
  avisar('✅ Salvo');
}

