function cartao(it){
  var div=document.createElement('div');
  div.className='card';
  div.innerHTML='<div class="cname">'+it.d+'</div><div style="font-size:12px;color:var(--tx2);">Código: '+it.c+'</div>';
  div.onclick=function(){abrirForm(it.id);};
  return div;
}

function rLista(cont,itens){
  if(!cont)return;
  cont.innerHTML='';
  if(!itens.length){cont.innerHTML='<div class="empty">📦 Vazio</div>';return;}
  itens.forEach(function(it){cont.appendChild(cartao(it));});
}

function rEst(){
  // Atualizar textos dos botões de filtro
  var statusVal=el('filtro-status').value;
  var diasVal=el('filtro-dias').value;
  
  var statusTextos={'':'📌 Todos Status','AGUARDANDO':'⏰ Aguardando','BAIXA':'📉 Baixa Preço','RELANCADOR':'🔄 Relançar'};
  var diasTextos={'':'📅 Todos Períodos','vencido':'⚠️ Crítico','hoje':'⚡ Atenção','semana':'📦 Relançar','mes':'🏷️ Baixa de Preço','futuro':'✅ Sem urgência'};
  
  el('btn-filtro-status').textContent=statusTextos[statusVal]||'📌 Todos Status';
  el('btn-filtro-dias').textContent=diasTextos[diasVal]||'📅 Todos Períodos';
  
  var est=getEst();
  var buscaEl=el('busca');
  var q=(buscaEl?buscaEl.value:'').toLowerCase();
  
  var statusEl=el('filtro-status');
  var statusFiltro=statusEl?statusEl.value:'';
  
  var diasEl=el('filtro-dias');
  var diasFiltro=diasEl?diasEl.value:'';
  
  var d=est.filter(function(i){
    // Filtro por busca (código ou descrição)
    var buscaOk=!q||i.c.includes(q)||i.d.toLowerCase().includes(q);
    
    // Filtro por status
    var statusOk=!statusFiltro||i.s===statusFiltro;
    
    // Filtro por dias até vencer
    var diasOk=true;
    if(diasFiltro){
      var partesData=i.v.split('-');
      var dataVenc=new Date(parseInt(partesData[0]),parseInt(partesData[1])-1,parseInt(partesData[2]));
      var hoje=new Date();
      hoje.setHours(0,0,0,0);
      var diasFaltando=Math.ceil((dataVenc-hoje)/(1000*60*60*24));
      
      if(diasFiltro==='vencido')diasOk=diasFaltando<0;
      else if(diasFiltro==='hoje')diasOk=diasFaltando===0;
      else if(diasFiltro==='semana')diasOk=diasFaltando>=2&&diasFaltando<=7;
      else if(diasFiltro==='mes')diasOk=diasFaltando>=16&&diasFaltando<=30;
      else if(diasFiltro==='futuro')diasOk=diasFaltando>30;
    }
    
    return buscaOk&&statusOk&&diasOk;
  });
  
  var cnt=document.getElementById('cnt');
  if(cnt)cnt.textContent=d.length+' itens';
  rLista(document.getElementById('le'),d);
}

