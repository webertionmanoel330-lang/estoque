  clearTimeout(timeoutDesfazer);
  var barra=document.createElement('div');
  barra.id='barra-desfazer';
  barra.style.cssText='position:fixed;bottom:80px;left:50%;transform:translateX(-50%);width:calc(100% - 32px);max-width:398px;background:var(--sf);border:1px solid var(--bd);border-radius:10px;padding:12px 14px;display:flex;flex-direction:column;gap:10px;z-index:100;animation:ti .2s ease;';
  
  var conteudo=document.createElement('div');
  conteudo.style.cssText='display:flex;align-items:center;gap:10px;';
  
  var txt=document.createElement('div');
  txt.style.cssText='flex:1;font-size:13px;font-weight:600;color:var(--tx);';
  txt.textContent=msg;
  conteudo.appendChild(txt);
  
  var btnX=document.createElement('button');
  btnX.style.cssText='background:transparent;border:none;color:var(--tx2);font-size:18px;cursor:pointer;padding:0;flex-shrink:0;';
  btnX.textContent='✕';
  btnX.onclick=function(){cancelarDesfazer();};
  conteudo.appendChild(btnX);
  
  barra.appendChild(conteudo);
  
  var contador=document.createElement('div');
  contador.style.cssText='width:100%;height:8px;background:var(--bd);border-radius:4px;position:relative;overflow:hidden;';
  var barraProgresso=document.createElement('div');
  barraProgresso.style.cssText='height:100%;background:var(--red);animation:countdown 5s linear forwards;';
  contador.appendChild(barraProgresso);
  barra.appendChild(contador);
  
  if(document.getElementById('barra-desfazer')){document.getElementById('barra-desfazer').remove();}
  document.body.appendChild(barra);
  timeoutDesfazer=setTimeout(function(){confirmarAcao();},5000);
}

function cancelarDesfazer(){
  clearTimeout(timeoutDesfazer);
  if(document.getElementById('barra-desfazer')){document.getElementById('barra-desfazer').remove();}
  if(ultimaAcao){
    if(ultimaAcao.tipo==='deletar'){lojas.splice(ultimaAcao.indice,0,ultimaAcao.lojaAntiga);salvarLocal();renderLojas();renderTudo();}
    else if(ultimaAcao.tipo==='limpar'){var l=lojas.find(function(x){return x.id===ultimaAcao.lojaId;});l.dados=ultimaAcao.dadosAntigos;salvarLocal();renderLojas();renderTudo();}
  }
  avisar('✅ Ação cancelada');
  ultimaAcao=null;
}

function confirmarAcao(){
  if(document.getElementById('barra-desfazer')){document.getElementById('barra-desfazer').remove();}
}

function carregarLocal(){
  try{
    var dadosSalvos=localStorage.getItem('sc5_lojas');
    if(dadosSalvos){
      lojas=JSON.parse(dadosSalvos);
    }else{
      lojas=[];
    }
  }catch(e){
    lojas=[];
    avisar('⚠️ Erro ao carregar dados!');
  }
  if(!lojas.length){lojas=[{id:'loja1',nome:'Loja 1',dados:[]}];}
  try{lojaAtiva=localStorage.getItem('sc5_lojaAtiva')||'loja1';}catch(e){lojaAtiva='loja1';}
}

function salvarLocal(){
  try{
    localStorage.setItem('sc5_lojas',JSON.stringify(lojas));
    localStorage.setItem('sc5_lojaAtiva',lojaAtiva);
  }catch(e){
    avisar('⚠️ Erro ao salvar! Storage cheio?');
  }
}

function getLoja(){return lojas.find(function(l){return l.id===lojaAtiva;})||lojas[0];}
function getEst(){return getLoja().dados;}
