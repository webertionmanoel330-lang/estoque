// ===== EVENT MANAGER - SISTEMA CENTRALIZADO DE LISTENERS =====
var EventManager={
  listeners: {},
  
  register: function(actionName, handler){
    this.listeners[actionName]=handler;
  },
  
  setup: function(){
    var self=this;
    // Encontrar todos os elementos com data-action
    document.querySelectorAll('[data-action]').forEach(function(el){
      var action=el.dataset.action;
      if(self.listeners[action]){
        el.addEventListener('click', self.listeners[action]);
      }
    });
    
    // Listeners especiais para inputs e selects
    var busca=document.getElementById('busca');
    if(busca)busca.addEventListener('input', rEst);
    
    // Navigation buttons
