function aplicarTraducoes(codigo){
  var trad=traducoes[codigo];
  if(!trad) return; // Se idioma não tem tradução, manter português
  
  // Traduzir textos principais
  for(var chave in trad){
    // Traduzir elementos com data-trad
    var elementos=document.querySelectorAll('[data-trad="'+chave+'"]');
    if(elementos&&elementos.length){
      elementos.forEach(function(el){
        if(el)el.textContent=trad[chave];
      });
    }
    
    // Traduzir placeholders
    var inputs=document.querySelectorAll('[data-trad-placeholder="'+chave+'"]');
    if(inputs&&inputs.length){
      inputs.forEach(function(el){
        if(el)el.placeholder=trad[chave];
      });
    }
    
    // Traduzir títulos de botões
    var btns=document.querySelectorAll('[data-trad-title="'+chave+'"]');
    if(btns&&btns.length){
      btns.forEach(function(el){
        if(el)el.title=trad[chave];
      });
    }
  }
}

