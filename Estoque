function gerarRelatorio(){
  try{
    var est=getEst();
    var html='<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Relatório</title><style>body{font-family:Arial;margin:20px;background:#f5f5f5;}table{width:100%;border-collapse:collapse;background:#fff;}th,td{border:1px solid #ccc;padding:10px;text-align:left;}th{background:#333;color:#fff;}</style></head><body>';
    html+='<h2>Relatório de Produtos</h2>';
    html+='<p><strong>Gerado em:</strong> '+new Date().toLocaleString()+'</p>';
    html+='<p><strong>Loja:</strong> '+getLoja().nome+'</p>';
    html+='<h3>Resumo</h3>';
    html+='<p><strong>Total de produtos:</strong> '+est.length+'</p>';
    var por_status={};
    est.forEach(function(i){por_status[i.s]=(por_status[i.s]||0)+1;});
    Object.keys(por_status).forEach(function(s){html+='<p>'+s+': '+por_status[s]+'</p>';});
    html+='<h3>Produtos</h3>';
    html+='<table><tr><th>Código</th><th>Descrição</th><th>Vencimento</th><th>Status</th></tr>';
    est.forEach(function(i){html+='<tr><td>'+i.c+'</td><td>'+i.d+'</td><td>'+i.v+'</td><td>'+i.s+'</td></tr>';});
    html+='</table></body></html>';
    
    // Tentar abrir em nova aba
    var win=window.open('');
    if(win){
      win.document.write(html);
      win.document.close();
      avisar('📄 Relatório aberto em nova aba!');
    }else{
      // Se window.open falhar, baixar como arquivo
      var blob=new Blob([html],{type:'text/html'});
      var url=window.URL.createObjectURL(blob);
      var a=document.createElement('a');
      a.href=url;
      a.download='relatorio-'+new Date().getTime()+'.html';
      a.click();
      window.URL.revokeObjectURL(url);
      avisar('📄 Relatório baixado!');
    }
  }catch(e){
    avisar('❌ Erro ao gerar relatório: '+e.message);
  }
}

